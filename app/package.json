{
  "name": "shopease",
  "version": "1.0.0",
  "description": "ShopEase E-Commerce Platform",
  "main": "server.js",
  "author": "Dhruvin Parmar",
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test": "jest --coverage --forceExit",
    "test:ci": "jest --coverage --forceExit --ci",
    "build": "node build.js"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "body-parser": "^1.20.2",
    "connect-flash": "^0.1.1",
    "ejs": "^3.1.9",
    "express": "^4.18.2",
    "express-session": "^1.17.3",
    "method-override": "^3.0.0"
  },
  "devDependencies": {
    "fs-extra": "^11.3.4",
    "jest": "^29.7.0",
    "nodemon": "^3.0.1",
    "supertest": "^6.3.3"
  },
  "jest": {
    "testEnvironment": "node",
    "collectCoverageFrom": [
      "routes/**/*.js",
      "models/**/*.js",
      "middleware/**/*.js"
    ],
    "coverageReporters": [
      "lcov",
      "text"
    ]
  }
}

<%- include('partials/header') %>

<div class="container login-page">
  <div class="login-card">
    <div class="login-logo">Shop<span>Ease</span></div>
    <h2>Admin Login</h2>
    <form action="/auth/login" method="POST">
      <div class="form-group">
        <label>Username</label>
        <input type="text" name="username" placeholder="admin" required/>
      </div>
      <div class="form-group">
        <label>Password</label>
        <input type="password" name="password" placeholder="••••••••" required/>
      </div>
      <button type="submit" class="btn-primary" style="width:100%;">Login &rarr;</button>
    </form>
    <p style="text-align:center;margin-top:1rem;"><a href="/" style="color:#888;font-size:0.85rem;">&larr; Back to Store</a></p>
  </div>
</div>

<%- include('partials/footer') %>

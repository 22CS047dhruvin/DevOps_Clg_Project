<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title><%= title %></title>
  <link rel="preconnect" href="https://fonts.googleapis.com"/>
  <link href="https://fonts.googleapis.com/css2?family=Syne:wght@600;700;800&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet"/>
  <link rel="stylesheet" href="/css/style.css"/>
</head>
<body>

<nav class="navbar">
  <div class="nav-inner">
    <a href="/" class="logo">Shop<span>Ease</span></a>
    <div class="nav-right">
      <a href="/" class="nav-link">Store</a>
      <a href="/track-order" class="nav-link">Track Order</a>
      <% if (isAdmin) { %>
        <a href="/admin" class="nav-link">Admin Panel</a>
        <a href="/auth/logout" class="btn-outline">Logout</a>
      <% } else { %>
        <a href="/auth/login" class="nav-link">Admin</a>
      <% } %>
      <a href="/cart" class="cart-btn">
        🛒 Cart <% if (cartCount > 0) { %><span class="badge"><%= cartCount %></span><% } %>
      </a>
    </div>
  </div>
</nav>

<% if (success && success.length > 0) { %>
  <div class="alert alert-success"><%= success %></div>
<% } %>
<% if (error && error.length > 0) { %>
  <div class="alert alert-error"><%= error %></div>
<% } %>

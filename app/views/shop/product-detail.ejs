<%- include('../partials/header') %>

<div class="container" style="padding-top:2rem;">
  <a href="/" class="back-link">&larr; Back to Store</a>

  <div class="detail-grid">
    <div class="detail-img">
      <img src="<%= product.image %>" alt="<%= product.name %>"/>
    </div>
    <div class="detail-info">
      <div class="product-cat"><%= product.category %></div>
      <h1 class="detail-title"><%= product.name %></h1>
      <div class="detail-price">&#8377;<%= product.price.toLocaleString('en-IN') %></div>
      <p class="detail-desc"><%= product.description %></p>
      <div class="stock-badge <%= product.stock > 0 ? 'in-stock' : 'out-stock' %>">
        <%= product.stock > 0 ? '&#10003; In Stock (' + product.stock + ' available)' : '&#10007; Out of Stock' %>
      </div>
      <% if (product.stock > 0) { %>
        <form action="/cart/add" method="POST" class="detail-form">
          <input type="hidden" name="productId" value="<%= product.id %>"/>
          <label>Quantity:</label>
          <input type="number" name="quantity" value="1" min="1" max="<%= product.stock %>"/>
          <button type="submit" class="btn-primary">Add to Cart 🛒</button>
        </form>
      <% } %>
    </div>
  </div>
</div>

<%- include('../partials/footer') %>
